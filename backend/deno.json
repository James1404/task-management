{
    "nodeModulesDir": "auto",
    "tasks": {
        "dev": "deno run -A --watch src/index.ts",
        "db:generate": "deno run -A --env=.env npm:prisma generate",
        "db:push": "deno run -A --env=.env npm:prisma db push",
        "db:migrate": "deno run -A --env=.env npm:prisma migrate dev",
        "db:studio": "deno run -A --env=.env npm:prisma studio",
        "openapi": "deno run -A npm:openapi-typescript ./openapi/openapi.yaml -o ./generated/openapi/openapi.d.ts"
    },
    "imports": {
        "@fastify/type-provider-typebox": "npm:@fastify/type-provider-typebox@^6.1.0",
        "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.4.1",
        "@prisma/client": "npm:@prisma/client@^7.4.1",
        "@sinclair/typebox": "npm:@sinclair/typebox@^0.34.48",
        "@std/assert": "jsr:@std/assert@1",
        "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
        "@std/yaml": "jsr:@std/yaml@^1.0.12",
        "@types/node": "npm:@types/node@^25.3.0",
        "@types/pg": "npm:@types/pg@^8.16.0",
        "fastify": "npm:fastify@^5.7.4",
        "fastify-plugin": "npm:fastify-plugin@^5.1.0",
        "openapi-typescript": "npm:openapi-typescript@^7.13.0",
        "pg": "npm:pg@^8.18.0",
        "prisma": "npm:prisma@^7.4.1",
        "uuid": "npm:uuid@^13.0.0",
        "zod": "npm:zod@^4.3.6"
    }
}
